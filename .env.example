# Handshake — environment variables.
# Copy to .env.local for local dev, or use .env.render to bulk-import into Render.
# NEXT_PUBLIC_* values are exposed to the browser and inlined at build time.

# --- Required: Supabase (boot & auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the deployment (used for tracking links, OAuth redirects,
# unsubscribe). Locally: http://localhost:3000 — on Render: the service URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Secrets for tokened features (generate strong random values) ---
TRACKING_SECRET=            # HMAC key for open/click tracking tokens
CRM_TOKEN_SECRET=           # encrypts stored CRM OAuth tokens
MAILBOX_TOKEN_SECRET=       # encrypts stored Gmail/Outlook mailbox OAuth tokens
EMAIL_WEBHOOK_SECRET=       # verifies inbound email webhook signatures

# --- Connected sending mailboxes (Gmail / Outlook via OAuth) ---
# Unset = the "Connect Gmail/Outlook" buttons are hidden and sending falls back
# to EMAIL_PROVIDER_API_KEY (Resend) / mock. Register these redirect URIs on the
# OAuth apps:
#   Google:    ${NEXT_PUBLIC_SITE_URL}/api/mailboxes/gmail/callback
#   Microsoft: ${NEXT_PUBLIC_SITE_URL}/api/mailboxes/outlook/callback
# NOTE: Google's gmail.send is a *restricted* scope — the Google Cloud OAuth app
# needs verification (CASA) before external users can connect in production.
GOOGLE_MAILBOX_CLIENT_ID=       # Google OAuth client for the gmail.send scope
GOOGLE_MAILBOX_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=            # Azure app registration with Mail.Send delegated
MICROSOFT_CLIENT_SECRET=

# --- Optional / feature-gated (unset = mock or feature disabled) ---
GOOGLE_PLACES_API_KEY=      # company lead search (else deterministic mock)
PEOPLE_SEARCH_API_KEY=      # Apollo people search (else mock; needs a PAID Apollo plan)
EMAIL_FROM=                 # from-address for outbound campaign email
EMAIL_PROVIDER_API_KEY=     # email sending provider key
REPLY_DOMAIN=               # domain for reply-tracking addresses
GOOGLE_CALENDAR_ACCESS_TOKEN=
SERVICETITAN_APP_KEY=
